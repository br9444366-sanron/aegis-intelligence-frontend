# =============================================================
# AEGIS INTELLIGENCE v2.1 — FRONTEND ENVIRONMENT VARIABLES
# =============================================================
# Copy this file to .env and fill in your real values.
# All Vite env vars MUST start with VITE_ to be exposed to the browser.

# ─────────────────────────────────────────
# BACKEND API
# ─────────────────────────────────────────
# URL of your Aegis backend (no trailing slash)
VITE_API_URL=http://localhost:4000/api

# ─────────────────────────────────────────
# FIREBASE (Web SDK — Client Side)
# ─────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your apps → Web app
# Click "Add app" if no web app exists yet, then copy the firebaseConfig values.

VITE_FIREBASE_API_KEY=AIzaSy_YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ─────────────────────────────────────────
# GOOGLE AUTH
# ─────────────────────────────────────────
# OAuth Client ID from: console.cloud.google.com → APIs & Services → Credentials
# Firebase Auth typically handles this automatically — only needed for manual OAuth flows.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ─────────────────────────────────────────
# GOOGLE GEMINI AI (Direct from Frontend — optional)
# ─────────────────────────────────────────
# WARNING: Only use this for development/prototyping.
# In production, all Gemini calls should go through your backend.
# Get your key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your-gemini-api-key-here
